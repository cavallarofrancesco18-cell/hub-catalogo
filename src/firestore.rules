/**
 * LuxDrive Catalog - Firestore Security Rules
 *
 * Core Philosophy:
 * This ruleset implements a role-based access control model. The primary goal is to provide a public, read-only vehicle catalog, while granting different levels of write permissions to 'Admins' and 'Sellers'.
 *
 * Data Structure:
 * - /vehicles/{vehicleId}: Public collection of all vehicle data.
 * - /roles_admin/{userId}: A list of admin UIDs. Document existence grants admin role.
 * - /roles_seller/{userId}: A list of seller UIDs. Document existence grants seller role.
 * - /forms/{formId}: Collection for storing form/document metadata.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper Functions
    
    /**
     * Checks if the user is authenticated.
     */
    function isSignedIn() {
      return request.auth != null;
    }
    
    /**
     * Checks if the user is an administrator by checking for their UID in the 'Admin' collection.
     */
    function isAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/Admin/$(request.auth.uid));
    }

    /**
     * Checks if the user is a seller by reading their user document.
     * Uses .get() with a default value for safety against missing fields.
     */
    function isSeller() {
        return isSignedIn() && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('role', null) == 'seller';
    }

    function isAgent() {
      return isSignedIn() && exists(/databases/$(database)/documents/agents/$(request.auth.uid));
    }

    function canWriteContracts() {
      return (isAdmin() || isSeller()) && request.auth.token.email != 'gp@gruppodinamica.com';
    }

    /**
     * @description
     *   Rules for the primary collection of vehicle listings.
     *   - Public read access for all.
     *   - Full write access for Admins.
     *   - Limited update access for Sellers (only description).
     * @path
     *   /vehicles/{vehicleId}
     */
    match /vehicles/{vehicleId} {
      allow get: if true;
      allow list: if true;

      allow create: if isAdmin();
      allow delete: if isAdmin();
      
      // Admins can update any field.
      allow update: if isAdmin();
      
      // Sellers can only update 'descrizione'.
      // We also ensure that 'updatedAt' is being set to the server time.
      allow update: if isSeller()
                    && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['descrizione', 'updatedAt'])
                    && request.resource.data.updatedAt == request.time;
      
      // Any signed in user can also change the status from 'In vendita' to 'Prenotato'.
      allow update: if isSignedIn()
                    && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['stato', 'updatedAt', 'statusChangedBy', 'statusChangedByName', 'statusChangedByEmail', 'reservationCreatedAt', 'reservationExpiresAt'])
                    && resource.data.stato == 'In vendita'
                    && request.resource.data.stato == 'Prenotato'
                    && request.resource.data.updatedAt == request.time;
    }

    /**
     * @description
     *   Admin roles collection. Reading is allowed for any signed in user to allow role checks.
     *   Writes are restricted to other admins to prevent self-promotion.
     * @path
     *   /Admin/{userId}
     */
    match /Admin/{userId} {
      // Allow any authenticated user to read admin roles. This is needed to break recursive checks.
      allow get, list: if isSignedIn();
      // Only existing admins can add/remove other admins.
      allow write: if isAdmin();
    }

    /**
     * @description
     *   Rules for the forms collection.
     *   - Authenticated users can read/list forms.
     *   - Only Admins can create, update, or delete forms.
     * @path
     *   /forms/{formId}
     */
    match /forms/{formId} {
      allow get, list: if isSignedIn();
      allow create, update, delete: if isAdmin();
    }

    /**
     * @description
     *   Shared HUB documents available to admins and seller users with sellerType HUB.
     * @path
     *   /hubDocuments/{documentId}
     */
    match /hubDocuments/{documentId} {
      function isHubSeller() {
        return isSignedIn()
          && exists(/databases/$(database)/documents/seller/$(request.auth.uid))
          && (
            get(/databases/$(database)/documents/seller/$(request.auth.uid)).data.sellerType == 'HUB'
            || get(/databases/$(database)/documents/seller/$(request.auth.uid)).data.sellerType == 'hub'
          );
      }

      allow get, list: if isAdmin() || isHubSeller();
      allow create, update, delete: if isAdmin() || isHubSeller();
    }

    match /hubDocumentFolders/{folderId} {
      function isHubSellerForFolders() {
        return isSignedIn()
          && exists(/databases/$(database)/documents/seller/$(request.auth.uid))
          && (
            get(/databases/$(database)/documents/seller/$(request.auth.uid)).data.sellerType == 'HUB'
            || get(/databases/$(database)/documents/seller/$(request.auth.uid)).data.sellerType == 'hub'
          );
      }

      allow get, list: if isAdmin() || isHubSellerForFolders();
      allow create, update, delete: if isAdmin() || isHubSellerForFolders();
    }

    /**
     * @description
     *   Rules for the user profiles collection.
     * @path
     *   /users/{userId}
     */
    match /users/{userId} {
      // An admin can perform any write operation (create, update, delete).
      allow write: if isAdmin();
      // A user can create their own profile document (e.g., during registration).
      allow create: if isSignedIn() && request.auth.uid == userId;
      
      // Admins can see all user profiles, users can only see their own.
      allow get: if isAdmin() || (isSignedIn() && request.auth.uid == userId);
      allow list: if isAdmin();
    }

    /**
     * @description
     *   Rules for agent profiles managed by admins.
     * @path
     *   /agents/{agentId}
     */
    match /agents/{agentId} {
      allow write: if isAdmin();
      allow create: if isSignedIn() && request.auth.uid == agentId;
      allow get: if isAdmin() || (isSignedIn() && request.auth.uid == agentId);
      allow list: if isAdmin();
    }

    /**
     * @description
     *   Reports submitted by agents for damaged vehicles.
     * @path
     *   /agentVehicleReports/{reportId}
     */
    match /agentVehicleReports/{reportId} {
      allow create: if isAgent() && request.resource.data.agentId == request.auth.uid;
      allow get: if isAdmin() || (isAgent() && resource.data.agentId == request.auth.uid);
      allow list: if isAdmin();
      allow update: if isAdmin()
        || (isAgent()
          && resource.data.agentId == request.auth.uid
          && request.resource.data.agentId == resource.data.agentId);
      allow delete: if isAdmin();
    }

    /**
     * @description
     *   Rules for the contracts collection.
     *   The contractId is the same as the vehicleId.
     * @path
     *   /contracts/{contractId}
     */
    match /contracts/{contractId} {
      // Admins can always read contracts.
      allow read: if isAdmin();
      
      // Admins and sellers except the blocked account can create contracts.
      allow create: if canWriteContracts()
                    && request.resource.data.creatorId == request.auth.uid;
      
      // Admins can always read contracts.
      allow get: if isAdmin();

      // Admins and sellers except the blocked account can update contracts.
      allow update: if canWriteContracts();

      
      // No one can list all contracts except admins (covered by first rule).
      allow list: if isAdmin();
      allow delete: if isAdmin();
    }

    /**
     * @description
     *   Rules for saved customer company profiles used in admin contract creation.
     * @path
     *   /customerCompanies/{companyId}
     */
    match /customerCompanies/{companyId} {
      allow get, list, create, update, delete: if isAdmin();
    }
  }
}
