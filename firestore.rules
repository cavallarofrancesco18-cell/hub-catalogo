
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper Functions
    
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isAdmin() {
      return isSignedIn() && request.auth.uid == '4E6MSEuIXZeeo3j2taWIA7LbYcw2';
    }

    function isSeller() {
        return isSignedIn() && exists(/databases/$(database)/documents/sellers/$(request.auth.uid));
    }

    match /vehicles/{vehicleId} {
      allow get: if true;
      allow list: if true;

      allow create: if isAdmin();
      allow delete: if isAdmin();
      
      allow update: if isAdmin();
    }

    match /forms/{formId} {
      allow get, list: if isAdmin() || isSeller();
      allow create, update, delete: if isAdmin();
    }
    
    match /sellers/{sellerId} {
      // Allow a user to be created in the sellers collection during registration.
      allow create: if isSignedIn() && request.auth.uid == sellerId;

      // Only admins can manage sellers.
      allow list, update, delete: if isAdmin();

      // A seller can read their own document, and an admin can read any seller document.
      // This is required for the useUserRole hook.
      allow get: if (isSignedIn() && request.auth.uid == sellerId) || isAdmin();
    }

    match /contracts/{contractId} {
      allow read, write: if isAdmin();
      
      allow create: if (isAdmin() || isSeller()) && request.resource.data.creatorId == request.auth.uid;
      
      allow get, update: if isSignedIn() && resource.data.creatorId == request.auth.uid;
      
      allow list: if isAdmin();
      allow delete: if isAdmin();
    }
  }
}
