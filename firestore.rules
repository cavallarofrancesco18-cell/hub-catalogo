/**
 * LuxDrive Catalog - Firestore Security Rules
 *
 * Core Philosophy:
 * This ruleset implements a simple authentication-based access control model. The primary goal is to provide a public, read-only vehicle catalog while limiting all write operations (creating, updating, or deleting vehicles) to any authenticated user. The login page acts as the primary gate for administrative access.
 *
 * Data Structure:
 * The data is organized into one primary collection:
 * 1. /vehicles/{vehicleId}: A public collection containing all vehicle data.
 *
 * Key Security Decisions:
 * - Public Vehicle Catalog: The `/vehicles` collection is publicly readable (`allow read: if true;`) to allow any user, authenticated or not, to browse the catalog. This is safe as vehicle documents contain no private user information.
 * - Authenticated-Only Writes: All write operations on the `/vehicles` collection are gated by an `isAdmin()` check. For simplicity, any user who is signed in is considered an admin.
 * - No Data Shape Validation: In accordance with the prototyping philosophy, these rules focus exclusively on authorization. The shape, types, or presence of fields within a 'Vehicle' document are not validated, allowing for rapid iteration on the data model.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper Functions
    
    /**
     * Checks if the user is authenticated.
     */
    function isSignedIn() {
      return request.auth != null;
    }
    
    /**
     * Checks if the user is an administrator.
     * For this application, any signed-in user is considered an admin.
     */
    function isAdmin() {
      return isSignedIn();
    }

    /**
     * @description
     *   Rules for the primary collection of vehicle listings.
     *   Allows public read access for all users to view the catalog.
     *   Restricts all write operations (create, update, delete) to authenticated users.
     * @path
     *   /vehicles/{vehicleId}
     */
    match /vehicles/{vehicleId} {
      allow get: if true;
      allow list: if true;
      allow create: if isAdmin();
      allow update: if isAdmin() && resource != null;
      allow delete: if isAdmin() && resource != null;
    }

    /**
     * @description
     *   This collection is not actively used in the simplified security model
     *   but is locked down to prevent any client-side access.
     * @path
     *   /roles_admin/{userId}
     */
    match /roles_admin/{userId} {
      allow read, write: if false;
    }
  }
}
