
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper Functions
    
    function isSignedIn() {
      return request.auth != null;
    }
    
    // DEVELOPMENT ONLY: Grants admin rights to any authenticated user (including anonymous).
    // This is for development purposes while the login flow is being rebuilt.
    // For PRODUCTION, comment this out and use the rule below.
    function isAdmin() {
      return isSignedIn();
    }

    /*
    // PRODUCTION RULE:
    function isAdmin() {
      return isSignedIn() 
             && exists(/databases/$(database)/documents/users/$(request.auth.uid))
             && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }
    */

    function isSeller() {
        return isSignedIn()
               && exists(/databases/$(database)/documents/users/$(request.auth.uid))
               && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('role', null) == 'seller';
    }

    match /vehicles/{vehicleId} {
      allow get: if true;
      allow list: if true;

      allow create: if isAdmin();
      allow delete: if isAdmin();
      
      allow update: if isAdmin();
      
      allow update: if isSeller()
                    && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['descrizione', 'updatedAt'])
                    && request.resource.data.updatedAt == request.time;

      allow update: if (isSeller())
                    && request.resource.data.diff(resource.data).affectedKeys().isSubsetOf(['stato', 'statusChangedBy', 'updatedAt'])
                    && request.resource.data.updatedAt == request.time
                    && (
                      (resource.data.stato == 'In vendita' && request.resource.data.stato == 'Prenotato' && request.resource.data.statusChangedBy == request.auth.uid) ||
                      (resource.data.statusChangedBy == request.auth.uid)
                    );
    }

    match /forms/{formId} {
      allow get, list: if isSeller() || isAdmin();
      allow create, update, delete: if isAdmin();
    }

    match /users/{userId} {
      allow write: if isAdmin();
      
      allow create: if isSignedIn() && request.auth.uid == userId;
      
      allow get: if isAdmin() || (isSignedIn() && request.auth.uid == userId);
      allow list: if isAdmin();
    }

    match /contracts/{contractId} {
      allow read, write: if isAdmin();
      
      allow create: if (isAdmin() || isSeller()) && request.resource.data.creatorId == request.auth.uid;
      
      allow get, update: if isSignedIn() && resource.data.creatorId == request.auth.uid;
      
      allow list: if isAdmin();
      allow delete: if isAdmin();
    }
  }
}
