
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper Functions
    
    function isSignedIn() {
      return request.auth != null;
    }
    
    // Grants admin rights to the specified user UID.
    function isAdmin() {
      return isSignedIn() && request.auth.uid == '4E6MSEuIXZeeo3j2taWIA7LbYcw2';
    }

    match /vehicles/{vehicleId} {
      allow get: if true;
      allow list: if true;

      allow create: if isAdmin();
      allow delete: if isAdmin();
      
      allow update: if isAdmin();
    }

    match /forms/{formId} {
      allow get, list: if isAdmin();
      allow create, update, delete: if isAdmin();
    }

    match /users/{userId} {
      allow write: if isAdmin();
      
      allow create: if isSignedIn() && request.auth.uid == userId;
      
      allow get: if isAdmin() || (isSignedIn() && request.auth.uid == userId);
      allow list: if isAdmin();
    }

    match /contracts/{contractId} {
      allow read, write: if isAdmin();
      
      allow create: if isAdmin() && request.resource.data.creatorId == request.auth.uid;
      
      allow get, update: if isSignedIn() && resource.data.creatorId == request.auth.uid;
      
      allow list: if isAdmin();
      allow delete: if isAdmin();
    }
  }
}
