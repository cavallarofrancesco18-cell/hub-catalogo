/**
 * LuxDrive Catalog - Firestore Security Rules
 *
 * Core Philosophy:
 * This ruleset implements a role-based access control model. The primary goal is to provide a public, read-only vehicle catalog, while granting different levels of write permissions to 'Admins' and 'Sellers'.
 *
 * Data Structure:
 * - /vehicles/{vehicleId}: Public collection of all vehicle data.
 * - /Admin/{userId}: A list of admin UIDs. Document existence grants admin role.
 * - /users/{userId}: Contains user profiles. If a user is a seller, their document contains `role: 'seller'`.
 * - /forms/{formId}: Collection for storing form/document metadata.
 * - /users/{userId}: Basic profile data for all registered users.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper Functions
    
    /**
     * Checks if the user is authenticated.
     */
    function isSignedIn() {
      return request.auth != null;
    }
    
    /**
     * Checks if the user is an administrator by checking for their UID in the 'Admin' collection.
     */
    function isAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/Admin/$(request.auth.uid));
    }

    /**
     * Checks if the user is a seller by reading their user document.
     */
    function isSeller() {
        return isSignedIn() && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'seller';
    }

    /**
     * @description
     *   Rules for the primary collection of vehicle listings.
     *   - Public read access for all.
     *   - Full write access for Admins.
     *   - Limited update access for Sellers (only description).
     * @path
     *   /vehicles/{vehicleId}
     */
    match /vehicles/{vehicleId} {
      allow get: if true;
      allow list: if true;

      allow create: if isAdmin();
      allow delete: if isAdmin();
      
      // Admins can update any field.
      allow update: if isAdmin();
      
      // Sellers can only update 'descrizione'.
      // We also ensure that 'updatedAt' is being set to the server time.
      allow update: if isSeller()
                    && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['descrizione', 'updatedAt'])
                    && request.resource.data.updatedAt == request.time;
      
      // Sellers can also change the status from 'In vendita' to 'Prenotato'.
      allow update: if isSeller()
                    && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['stato', 'updatedAt', 'statusChangedBy'])
                    && resource.data.stato == 'In vendita'
                    && request.resource.data.stato == 'Prenotato'
                    && request.resource.data.updatedAt == request.time;
    }

    /**
     * @description
     *   Admin roles collection. Reading is allowed for admins and for a user reading their own role.
     *   Writes are restricted to other admins.
     * @path
     *   /Admin/{userId}
     */
    match /Admin/{userId} {
      allow get: if isAdmin() || (isSignedIn() && request.auth.uid == userId);
      allow list, create, update, delete: if isAdmin();
    }

    /**
     * @description
     *   Rules for the forms collection.
     *   - Authenticated users can read/list forms.
     *   - Only Admins can create, update, or delete forms.
     * @path
     *   /forms/{formId}
     */
    match /forms/{formId} {
      allow get, list: if isSignedIn();
      allow create, update, delete: if isAdmin();
    }

    /**
     * @description
     *   Rules for the user profiles collection.
     * @path
     *   /users/{userId}
     */
    match /users/{userId} {
      // An admin can perform any write operation (create, update, delete).
      allow write: if isAdmin();
      // A user can create their own profile document (e.g., during registration).
      allow create: if request.auth.uid == userId;
      
      // Admins can see all user profiles, users can only see their own.
      allow get: if isAdmin() || request.auth.uid == userId;
      allow list: if isAdmin();
    }

    /**
     * @description
     *   Rules for the contracts collection.
     *   The contractId is the same as the vehicleId.
     * @path
     *   /contracts/{contractId}
     */
    match /contracts/{contractId} {
      // An Admin can do anything.
      allow read, write: if isAdmin();
      
      // A Seller can create a contract, ensuring they set themselves as the creator.
      allow create: if isSeller() && request.resource.data.creatorId == request.auth.uid;
      
      // A Seller can read or update a contract they created.
      allow get, update: if isSeller() && resource.data.creatorId == request.auth.uid;
      
      // No one can list all contracts except admins (covered by first rule).
      allow list: if isAdmin();
      allow delete: if isAdmin();
    }
  }
}
