
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper Functions
    
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isAdmin() {
      return isSignedIn() && request.auth.uid == '4E6MSEuIXZeeo3j2taWIA7LbYcw2';
    }

    function isSeller() {
        return isSignedIn() && exists(/databases/$(database)/documents/seller/$(request.auth.uid));
    }

    match /vehicles/{vehicleId} {
      allow get: if true;
      allow list: if true;

      allow create: if isAdmin();
      allow delete: if isAdmin();
      
      allow update: if isAdmin();

      // Any signed-in user can book a vehicle when creating a contract.
      allow update: if isSignedIn()
                    && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['stato', 'updatedAt', 'statusChangedBy'])
                    && resource.data.stato == 'In vendita'
                    && request.resource.data.stato == 'Prenotato'
                    && request.resource.data.statusChangedBy == request.auth.uid;
    }

    match /forms/{formId} {
      allow get, list: if isAdmin() || isSeller();
      allow create, update, delete: if isAdmin();
    }
    
    match /seller/{sellerId} {
      // Allow a user to be created in the sellers collection during registration.
      allow create: if isSignedIn() && request.auth.uid == sellerId;

      // Admins can list and delete sellers.
      allow list, delete: if isAdmin();
      
      // A user can update their own document (e.g. during registration), and an admin can update any document.
      allow update: if (isSignedIn() && request.auth.uid == sellerId) || isAdmin();

      // A seller can read their own document, and an admin can read any seller document.
      allow get: if (isSignedIn() && request.auth.uid == sellerId) || isAdmin();
    }

    match /contracts/{contractId} {
      // Admins can do anything.
      allow read, write: if isAdmin();
      
      // Any signed-in user can create a contract if they set themselves as creator.
      allow create: if isSignedIn() && request.resource.data.creatorId == request.auth.uid;
      
      // A user can read/update a contract they created.
      allow get, update: if isSignedIn() && resource.data.creatorId == request.auth.uid;
      
      // Only admins can list all contracts or delete them.
      allow list, delete: if isAdmin();
    }
  }
}
