
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper Functions
    
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    function isSeller() {
        return isSignedIn() && exists(/databases/$(database)/documents/sellers/$(request.auth.uid));
    }

    match /vehicles/{vehicleId} {
      allow get: if true;
      allow list: if true;

      allow create: if isAdmin();
      allow delete: if isAdmin();
      
      allow update: if isAdmin();
    }

    match /forms/{formId} {
      allow get, list: if isAdmin() || isSeller();
      allow create, update, delete: if isAdmin();
    }

    match /users/{userId} {
      allow read, write: if isAdmin();
    }
    
    match /sellers/{sellerId} {
      allow create: if isSignedIn() && request.auth.uid == sellerId;
      allow read, write: if isAdmin();
      allow list: if isAdmin();
    }

    match /contracts/{contractId} {
      allow read, write: if isAdmin();
      
      allow create: if (isAdmin() || isSeller()) && request.resource.data.creatorId == request.auth.uid;
      
      allow get, update: if isSignedIn() && resource.data.creatorId == request.auth.uid;
      
      allow list: if isAdmin();
      allow delete: if isAdmin();
    }
  }
}
