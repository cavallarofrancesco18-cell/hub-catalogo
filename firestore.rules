/**
 * LuxDrive Catalog - Firestore Security Rules
 *
 * Core Philosophy:
 * This ruleset implements a Database-Backed Access Control (DBAC) model. The primary goal is to provide a public, read-only vehicle catalog while strictly limiting all write operations (creating, updating, or deleting vehicles) to a predefined set of administrative users.
 *
 * Data Structure:
 * The data is organized into two distinct, top-level collections:
 * 1. /vehicles/{vehicleId}: A public collection containing all vehicle data.
 * 2. /roles_admin/{userId}: A private collection where the existence of a document grants a user administrative privileges.
 *
 * Key Security Decisions:
 * - Public Vehicle Catalog: The `/vehicles` collection is publicly readable (`allow read: if true;`) to allow any user, authenticated or not, to browse the catalog. This is safe as vehicle documents contain no private user information.
 * - Admin-Only Writes: All write operations on the `/vehicles` collection are gated by an `isAdmin()` check. A user is considered an admin if a corresponding document exists for them in the `/roles_admin` collection.
 * - Locked Admin Roles: The `/roles_admin` collection is completely locked down from all client-side access. This is a critical security measure to prevent any user (including other admins) from modifying roles through the application. Administrator roles must be managed manually via the Firebase Console or a trusted server-side process.
 * - No Data Shape Validation: In accordance with the prototyping philosophy, these rules focus exclusively on authorization. The shape, types, or presence of fields within a 'Vehicle' document are not validated, allowing for rapid iteration on the data model.
 *
 * Denormalization for Authorization:
 * This ruleset does not require denormalization on the vehicle documents themselves. Instead, it uses a separate `/roles_admin` collection as the source of truth for authorization. This is a clean and scalable pattern that avoids embedding role information into every vehicle document. An `exists()` call is used to perform the role check, which is a highly performant read operation.
 *
 * Structural Segregation:
 * The design strictly segregates public data (`/vehicles`) from sensitive authorization data (`/roles_admin`) into separate collections. This separation simplifies the rules, improves performance, and enhances security by applying different, unambiguous access policies to each collection.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper Functions
    
    /**
     * Checks if the user is authenticated.
     */
    function isSignedIn() {
      return request.auth != null;
    }
    
    /**
     * Checks if the authenticated user has an admin role.
     * An admin is defined by the existence of a document with their UID in the /roles_admin collection.
     */
    function isAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/roles_admin/$(request.auth.uid));
    }

    /**
     * @description
     *   Rules for the primary collection of vehicle listings.
     *   Allows public read access for all users to view the catalog.
     *   Restricts all write operations (create, update, delete) to authenticated administrators.
     * @path
     *   /vehicles/{vehicleId}
     * @allow
     *   (get) Any anonymous user can read a specific vehicle's details.
     *   (list) Any authenticated user can query the list of all vehicles.
     *   (create) An admin user can create a new vehicle listing.
     * @deny
     *   (update) An authenticated, non-admin user cannot update a vehicle's price.
     *   (delete) An anonymous user cannot delete a vehicle listing.
     * @principle
     *   Enforces a "Public Read, Admin Write" access control pattern using Database-Backed Access Control (DBAC).
     */
    match /vehicles/{vehicleId} {
      allow get: if true;
      allow list: if true;
      allow create: if isAdmin();
      allow update: if isAdmin() && resource != null;
      allow delete: if isAdmin() && resource != null;
    }

    /**
     * @description
     *   Rules for the collection that defines administrative roles.
     *   This collection is completely locked down from all client-side access.
     *   Its purpose is to serve as a lookup table for the `isAdmin()` helper function.
     * @path
     *   /roles_admin/{userId}
     * @allow
     *   No client-side access is permitted. Roles must be managed via the Firebase Console or a trusted backend.
     * @deny
     *   (get) An admin user cannot read another admin's role document.
     *   (create) A user cannot grant themselves admin privileges.
     * @principle
     *   Locks down critical administrative data from all client access to prevent privilege escalation.
     */
    match /roles_admin/{userId} {
      allow get: if false;
      allow list: if false;
      allow create: if false;
      allow update: if false;
      allow delete: if false;
    }
  }
}