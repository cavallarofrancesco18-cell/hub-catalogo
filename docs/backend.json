{
  "entities": {
    "Vehicle": {
      "title": "Vehicle",
      "description": "Represents a vehicle for sale.",
      "type": "object",
      "properties": {
        "data_inserimento": { "type": "string", "format": "date-time" },
        "stato": { "type": "string", "enum": ["In vendita", "Venduto"] },
        "marca": { "type": "string" },
        "modello": { "type": "string" },
        "versione": { "type": "string" },
        "anno": { "type": "number" },
        "chilometraggio": { "type": "number" },
        "carburante": { "type": "string", "enum": ["Benzina", "Diesel", "Elettrica", "Ibrida"] },
        "cambio": { "type": "string", "enum": ["Manuale", "Automatico"] },
        "potenza": { "type": "number", "description": "Potenza in CV" },
        "potenza_kw": { "type": "number" },
        "bollo": { "type": "string" },
        "cilindrata": { "type": "number" },
        "classe_emissioni": { "type": "string" },
        "colore_esterno": { "type": "string" },
        "colore_interni": { "type": "string" },
        "prezzo": { "type": "number" },
        "targa": { "type": "string" },
        "garanzia": { "type": "string" },
        "descrizione": { "type": "string" },
        "immagini": { "type": "array", "items": { "type": "string", "format": "uri" } },
        "link_canva": { "type": "string", "format": "uri" }
      },
      "required": ["marca", "modello", "anno", "prezzo", "data_inserimento", "stato", "chilometraggio", "carburante", "cambio", "potenza"]
    }
  },
  "auth": {
    "providers": []
  },
  "firestore": {
    "/vehicles/{vehicleId}": {
      "schema": { "$ref": "#/entities/Vehicle" },
      "description": "Stores vehicle listings."
    }
  }
}
