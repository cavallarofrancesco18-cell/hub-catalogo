rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    
    function isAdmin() {
      // Use 'Admin' or 'roles_admin' collection to check for admin role.
      return request.auth != null && (
        exists(/databases/$(database)/documents/Admin/$(request.auth.uid)) ||
        exists(/databases/$(database)/documents/roles_admin/$(request.auth.uid))
      );
    }

    // Rule for vehicle images.
    // Public 'get' for catalog display.
    // 'list' and 'write' for admins to manage images and use the folder import feature.
    match /download/{vehicleId}/{allPaths=**} {
      allow get: if true;
      allow list, write: if isAdmin();
    }

    // Rule for form documents.
    // Authenticated users can 'get' forms.
    // Admins can 'list' and 'write' to manage the forms.
    match /forms/{formId}/{allPaths=**} {
      allow get: if request.auth != null;
      allow list, write: if isAdmin();
    }

    // Publicly readable logos for branding
    match /LOGHI/{allPaths=**} {
      allow get: if true;
    }
    match /HUB - logo tutti formati_Tavola disegno 1 copia 4 (4).png {
        allow get: if true;
    }
     match /logo-restart-mobility-white-300x154.png {
        allow get: if true;
    }
     match /WhatsApp Image 2026-03-09 at 16.41.30.jpeg {
        allow get: if true;
    }
     match /Logo-1 trasparente.png {
        allow get: if true;
    }
  }
}
