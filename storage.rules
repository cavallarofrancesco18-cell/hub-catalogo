rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    // Allow public read access to all files.
    // This is necessary for the app to display images.
    match /vehicles/{vehicleId}/{allPaths=**} {
      allow read: if true;

      // Allow authenticated users to write (create, update, delete).
      // Restrict file size to 1MB.
      allow write: if request.auth != null && request.resource.size < 1 * 1024 * 1024;
    }
  }
}
